<view class="container" wx:if="{{result}}">
  <view class="card">
    <view class="inline-row">
      <view>
        <view class="title">{{result.roleLabel}} · {{result.levelLabel}}</view>
        <view class="subtitle">{{result.levelTag}}｜{{result.questionCount}} 题完成</view>
        <view class="subtitle">二答平均进步值：{{result.progressScore}}</view>
      </view>
      <view class="score-big">{{result.averageScore}}</view>
    </view>
  </view>

  <view class="tab-row">
    <view class="tab-btn {{reportTab === 0 ? 'active' : ''}}" data-index="0" bindtap="switchTab">
      报告1：最该改3点
    </view>
    <view class="tab-btn {{reportTab === 1 ? 'active' : ''}}" data-index="1" bindtap="switchTab">
      报告2：逐题详解
    </view>
  </view>

  <view wx:if="{{reportTab === 0}}">
    <view class="card">
      <view class="question-title">本次最该改的 3 点</view>
      <view wx:for="{{result.reportTop3}}" wx:key="*this" class="tip-item">• {{item}}</view>
    </view>

    <view class="card">
      <view class="question-title">6维雷达（文本版）</view>
      <view wx:for="{{result.dimensionRadarView}}" wx:key="key" class="radar-row">
        <view class="radar-label">{{item.label}} {{item.value}}</view>
        <view class="bar-bg">
          <view class="bar-value" style="width: {{item.barWidth}};"></view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{reportTab === 1}}">
    <view class="card" wx:for="{{result.recordsView}}" wx:key="questionId">
      <view class="record-title">Q{{index + 1}}. {{item.prompt}}</view>
      <view class="record-meta">题型：{{item.questionType}}</view>
      <view class="record-meta">一答 {{item.firstScore}} → 二答 {{item.secondScore}}（进步 {{item.progressValue}}）</view>
      <view class="record-meta" wx:if="{{item.secondModeLabel}}">二答模式：{{item.secondModeLabel}}</view>

      <view class="sub-title">任务拆解</view>
      <view wx:for="{{item.taskBreakdown}}" wx:key="*this" class="record-line">- {{item}}</view>

      <view class="sub-title">缺失要点补充模板</view>
      <view wx:for="{{item.missingPointTemplates}}" wx:key="point" class="record-line">
        - {{item.point}}：{{item.template}}
      </view>

      <view class="sub-title" wx:if="{{item.hitSentences.length > 0}}">命中要点句</view>
      <view wx:for="{{item.hitSentences}}" wx:key="*this" class="record-line">“{{item}}”</view>

      <view class="sub-title" wx:if="{{item.offTopicSentences.length > 0}}">疑似跑题句</view>
      <view wx:for="{{item.offTopicSentences}}" wx:key="*this" class="record-line warning">“{{item}}”</view>

      <view class="sub-title">江苏本地化素材建议</view>
      <view wx:for="{{item.localMaterialTips}}" wx:key="*this" class="record-line">- {{item}}</view>

      <view class="sub-title">一答原文</view>
      <view class="record-answer">{{item.firstAnswer || '（一答为空）'}}</view>

      <view class="sub-title">二答原文</view>
      <view class="record-answer">{{item.secondAnswer || '（二答为空）'}}</view>
    </view>
  </view>

  <button class="btn-primary" bindtap="restart">再来一轮</button>
  <button class="btn-secondary" bindtap="toHistory">历史记录</button>
</view>

<view wx:else class="empty">未找到结果，请返回首页重新开始。</view>
