<view class="container">
  <view class="card hero-card history-head">
    <view class="title">历史复盘档案</view>
    <view class="subtitle">按场次查看分数走势和二答进步值，持续追踪上岸节奏。</view>
  </view>

  <view wx:if="{{history.length === 0}}" class="empty">暂无历史记录，先开始一次模拟训练。</view>

  <view wx:else>
    <view class="card history-card" wx:for="{{history}}" wx:key="id" bindtap="openResult" data-id="{{item.id}}">
      <view class="inline-row">
        <view>
          <view class="record-role">{{item.roleLabel}} · {{item.levelLabel}}</view>
          <view class="record-time">{{item.createdAtText}}</view>
        </view>
        <view class="record-score">{{item.averageScore}}</view>
      </view>
      <view class="record-level">{{item.levelTag}}｜{{item.questionCount}} 题｜二答进步 {{item.progressScore || 0}}</view>
    </view>

    <button class="btn-secondary" bindtap="clearHistory">清空历史记录</button>
  </view>
</view>
