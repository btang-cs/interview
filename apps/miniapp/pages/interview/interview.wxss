.interview-head {
  border-color: #fdba74;
}

.track-pill {
  background: #ffffff;
  border: 1rpx solid #fdba74;
  color: #c2410c;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.clock-pill {
  background: #7f1d1d;
  color: #ffffff;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.phase-row {
  margin-top: 16rpx;
}

.phase-title {
  color: #7c2d12;
  font-size: 26rpx;
  font-weight: 600;
}

.phase-percent {
  color: #c2410c;
  font-size: 24rpx;
  font-weight: 700;
}

.timer-row {
  margin-top: 14rpx;
}

.timer-label {
  color: #92400e;
  font-size: 24rpx;
}

.meter {
  margin-top: 8rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #fed7aa;
  overflow: hidden;
}

.meter-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #fb923c, #ea580c);
}

.meter-time {
  background: #fde68a;
}

.meter-time-fill {
  background: linear-gradient(90deg, #f59e0b, #b45309);
}

.question-card {
  border-color: #fed7aa;
}

.question-head {
  align-items: center;
}

.question-title {
  font-weight: 700;
  color: #7c2d12;
}

.question-type {
  background: #fff7ed;
  border: 1rpx solid #fdba74;
  color: #c2410c;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
}

.question-text {
  margin-top: 10rpx;
  line-height: 1.8;
  color: #334155;
}

.answer-input {
  width: 100%;
  min-height: 260rpx;
  margin-top: 12rpx;
  background: #fffaf5;
  border: 1rpx solid #fed7aa;
  border-radius: 16rpx;
  padding: 18rpx;
  box-sizing: border-box;
  line-height: 1.7;
}

.feedback-card {
  background: linear-gradient(180deg, #fffaf0 0%, #ffffff 100%);
}

.feedback-head {
  align-items: center;
}

.feedback-score {
  color: #ea580c;
  background: #fff7ed;
  border: 1rpx solid #fdba74;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  font-weight: 700;
}

.sub-title {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  color: #9a3412;
  font-weight: 700;
}

.feedback-line {
  margin-top: 8rpx;
  color: #475569;
  line-height: 1.7;
}

.warning {
  color: #b91c1c;
}

.mode-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 10rpx;
}

.mode-btn {
  border: 1rpx solid #fdba74;
  background: #fffaf5;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  color: #7c2d12;
  font-size: 24rpx;
}

.mode-btn.active {
  border-color: #ea580c;
  color: #ffffff;
  background: linear-gradient(135deg, #fb923c, #ea580c);
}

.mode-tip {
  margin-top: 14rpx;
  margin-bottom: 14rpx;
  color: #14532d;
  background: linear-gradient(135deg, #f0fdf4 0%, #ecfeff 100%);
  border: 1rpx solid #86efac;
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
  line-height: 1.6;
}
